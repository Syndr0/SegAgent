# Start with the rule baseline before enabling the multimodal planner.
SEGAGENT_PLANNER=rule
SEGAGENT_VOXTELL_MODEL=/absolute/path/to/voxtell_v1.1
SEGAGENT_DEVICE=auto
SEGAGENT_REQUIRE_MASK_APPROVAL=true
SEGAGENT_TRACE_CONTENT=false

# Optional local interface settings.
SEGAGENT_API_BASE_URL=http://127.0.0.1:8000
SEGAGENT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
